# Supabase environment variables.
# Copy this file to .env.local and fill in your project values.
# NEVER commit .env.local or any real credentials.
#
# NEXT_PUBLIC_* variables are bundled into the client-side JavaScript bundle.
# Never put secrets in NEXT_PUBLIC_* variables.

# ── Public (browser-safe) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Server-only (NEVER expose to the browser) ─────────────────────────────────
# The service-role key bypasses Row Level Security.
# Use ONLY in Route Handlers (app/api/*) and Server Actions.
# IMPORTANT: must NOT be prefixed with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# HMAC secret for the saved-search "unsubscribe" link token
# (lib/saved-searches/unsubscribeToken.ts). Server-only.
SAVED_SEARCH_UNSUB_SECRET=change-me-to-a-long-random-string

# ── Mapbox (public — map tiles only) ─────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token-here
