# Supabase — copy this file to .env.local and fill in your project values.
# NEVER commit .env.local or any real credentials.
#
# NEXT_PUBLIC_* variables are bundled into the browser — never place secrets in them.
# SUPABASE_SERVICE_ROLE_KEY is server-only (route handlers / server actions).

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️  SERVER-ONLY — never prefix with NEXT_PUBLIC_, never import from client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
